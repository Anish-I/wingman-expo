{
  "expo": {
    "name": "Wingman",
    "slug": "wingman",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wingman",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF5E9"
    },
    "ios": {
      "bundleIdentifier": "com.aivat.wingman",
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Wingman uses speech recognition to turn your voice into text.",
        "NSMicrophoneUsageDescription": "Wingman uses the microphone for voice dictation in chat."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FBF5E9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.aivat.wingman"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Wingman uses the microphone for voice dictation in chat.",
          "speechRecognitionPermission": "Wingman uses speech recognition to turn your voice into text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67a53e77-d7de-45b0-9906-99d39fa60abb"
      }
    },
    "owner": "ghandour12"
  }
}
