PORT=3002
FRONTEND_URL=http://localhost:8082
# Public URL of THIS server (used to build OAuth callback URLs the browser hits).
# Defaults to http://localhost:PORT; set to the deployed API URL in production.
PUBLIC_API_URL=

# Database — Postgres connection string (required).
# Supabase: dashboard -> Connect -> use the SESSION pooler (IPv4-compatible, :5432).
#   NOT the transaction pooler (:6543) — schema setup uses session advisory locks.
#   postgresql://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
# For local dev you can run a throwaway Postgres in Docker:
#   docker run -d --name wingman-pg -e POSTGRES_PASSWORD=wingman -e POSTGRES_USER=wingman \
#     -e POSTGRES_DB=wingman -p 5433:5432 postgres:17-alpine
#   DATABASE_URL=postgres://wingman:wingman@localhost:5433/wingman
DATABASE_URL=postgres://wingman:wingman@localhost:5433/wingman
# TLS CA for verifying the DB cert. Supabase's pooler uses Supabase's own CA (not a
# public root), so download it (dashboard -> Project Settings -> Database -> SSL
# configuration) and point this at the file. Path is relative to the server/ dir.
#   DATABASE_CA_CERT_FILE=./certs/supabase-ca.crt
DATABASE_CA_CERT_FILE=
# Inline CA PEM alternative (used only when DATABASE_CA_CERT_FILE is unset).
# TLS is always verified; never disable it. Leave both empty to use system roots.
DATABASE_CA_CERT=

# LLM provider: "openai" | "mock" (falls back to mock when OPENAI_API_KEY is empty)
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
OPENAI_API_KEY=

# Composio — gives Pip real access to the user's apps.
# COMPOSIO_API_KEY enables the runtime; without per-toolkit auth configs no tools load.
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://backend.composio.dev
# Per-toolkit auth config ids created in the Composio dashboard. Format:
#   COMPOSIO_AUTH_CONFIGS=gmail=ac_xxx,googlecalendar=ac_yyy,slack=ac_zzz
COMPOSIO_AUTH_CONFIGS=
